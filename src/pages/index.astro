---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Icon } from "astro-icon/components";
import projects from "../data/projects.json";
import posts from "../data/posts.json";
import awards from "../data/awards.json";
import about from "../data/about.json";
import blogPosts from "../data/blog-posts.json";
---

<Layout 
  title="Hanif Adedotun - Software Engineer Portfolio"
  description="Hanif Adedotun - Software Engineer & Developer. Portfolio showcasing projects, blog posts, and technical expertise in modern web development."
  canonicalUrl="https://v2.hanif.one/"
>
  <div class="min-h-screen p-6 max-w-4xl mx-auto">
    <Header />

    <main class="space-y-24">
      {/* About Section - Enhanced */}
      <section class="animate-fade-in-up pt-4">
        <div class="space-y-4">
          {about.text.map((paragraph, index) => {
            // Handle both old string format and new segment format
            if (typeof paragraph === 'string') {
              return (
                <p 
                  class="text-lg leading-relaxed text-gray-700 dark:text-gray-300 transition-colors duration-300"
                  style={`animation: fadeInUp 0.6s ease-out ${index * 150}ms both`}
                >
                  {paragraph}
                </p>
              );
            }
            
            // New segment-based format
            return (
              <p 
                class="text-lg leading-relaxed text-gray-700 dark:text-gray-300 transition-colors duration-300"
                style={`animation: fadeInUp 0.6s ease-out ${index * 150}ms both`}
              >
                {paragraph.segments.map((segment, segIndex) => {
                  if (segment.type === 'highlight') {
                    return (
                      <span 
                        class="dark:!text-[#1DCFF6] !text-[#17b2d4] font-medium"
                      >
                        {segment.value}
                      </span>
                    );
                  }
                  if (segment.type === 'link' && segment.href) {
                    const isExternal = segment.href.startsWith('http') || segment.href.startsWith('mailto:');
                    return (
                      <a
                        href={segment.href}
                        target={isExternal ? '_blank' : undefined}
                        rel={segment.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                        class="dark:!text-[#1DCFF6] !text-[#17b2d4] hover:underline underline-offset-2 decoration-2 transition-all duration-300"
                      >
                        {segment.value}
                      </a>
                    );
                  }
                  return <span>{segment.value}</span>;
                })}
              </p>
            );
          })}
        </div>
        <a
          href="https://docs.google.com/document/d/1sC0lsScDSwPbR-SpXfl6cY_rcB67E4sgOdKBeQMlWqc/edit?usp=sharing"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-6 px-6 py-2.5 border-1 border-gray-900 dark:border-gray-100 text-gray-900 dark:text-gray-100 font-medium rounded-lg transition-all duration-300 hover:scale-105 active:scale-95"
          style="animation: fadeInUp 0.8s ease-out 450ms both"
        >
          View Resume
        </a>
      </section>

      {/* Blog Posts Section - Enhanced */}
      <section class="animate-fade-in-delay border-t border-gray-200 dark:border-gray-800 pt-8">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 dark:text-white">✍️ My thoughts</h2>
        </div>
        <div class="space-y-3">
          {
            blogPosts.slice(0, 5).map((post, index) => (
              <div 
                class="flex flex-row-reverse md:flex-row gap-6 text-base transition-all duration-300 hover:translate-x-2 group py-2 -mx-2 px-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-900/50"
                style={`animation: fadeInUp 0.5s ease-out ${index * 100}ms both`}
              >
                <span class="text-gray-500 text-right md:text-left shrink-0 w-24 md:w-28 text-sm font-medium group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors pt-0.5">
                  {new Date(post.date).toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </span>
                <a
                  href={`/blog/${post.slug}`}
                  class="hover:text-gray-900 dark:hover:text-white underline underline-offset-4 decoration-2 decoration-gray-300 dark:decoration-gray-700 hover:decoration-gray-900 dark:hover:decoration-gray-100 transition-all duration-300 flex-1"
                >
                  {post.title}
                </a>
              </div>
            ))
          }
        </div>
        <a
          href="/blog"
          class="text-base text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white block mt-6 underline underline-offset-4 transition-all duration-300 hover:translate-x-1 inline-block font-medium"
        >
          View all articles →
        </a>
      </section>

      {/* Projects Section - Enhanced */}
      <section class="animate-fade-in-delay border-t border-gray-200 dark:border-gray-800 pt-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 dark:text-white">
            🛠️ Some projects I've brought to life
          </h2>
        </div>
        <div class="space-y-8">
          {
            projects.slice(0, 3).map((project, index) => (
              <div 
                class="transition-all duration-300 hover:translate-x-2 group p-4 -mx-4 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-900/50 border border-transparent hover:border-gray-200 dark:hover:border-gray-800"
                style={`animation: fadeInUp 0.5s ease-out ${index * 100}ms both`}
              >
                <div class="flex items-center justify-between gap-2 mb-2">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-gray-700 dark:group-hover:text-gray-200 transition-colors duration-300">
                    {project.name[0]}
                  </h3>
                  <a
                    href={project.name[1]}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-all duration-300 hover:scale-110 active:scale-95"
                    aria-label={`Visit ${project.name[0]}`}
                  >
                    <Icon name="mdi:web" class="w-5 h-5" />
                  </a>
                </div>
                <p class="text-base text-gray-600 dark:text-gray-400 mb-4 leading-relaxed">
                  {project.summary}
                </p>
                <div class="flex flex-wrap gap-2">
                  {project.tools.map((tool: string, toolIndex: number) => (
                    <span 
                      class="text-sm px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 transition-all duration-300 hover:scale-105 hover:bg-gray-200 dark:hover:bg-gray-700 font-medium"
                      style={`animation: scaleIn 0.3s ease-out ${(index * 100) + (toolIndex * 50)}ms both`}
                    >
                      {tool}
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
        <a
          href="/projects"
          class="text-base text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white block mt-8 underline underline-offset-4 transition-all duration-300 hover:translate-x-1 inline-block font-medium"
        >
          View all projects →
        </a>
      </section>

      {/* Awards Section - Enhanced */}
      <section class="animate-fade-in-delay border-t border-gray-200 dark:border-gray-800 pt-8">
        <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 dark:text-white mb-6">🏆 Recognitions</h2>
        <div class="space-y-3">
          {
            awards.map((award, index) => (
              <div 
                class="flex gap-6 text-base transition-all duration-300 hover:translate-x-2 group py-2 -mx-2 px-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-900/50"
                style={`animation: fadeInUp 0.5s ease-out ${index * 100}ms both`}
              >
                <span class="text-gray-500 shrink-0 w-24 text-sm font-medium group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors pt-0.5">{award.date}</span>
                <span class="text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors flex-1">
                  {award.title}
                </span>
              </div>
            ))
          }
        </div>
      </section>
    </main>

    {/* Structured Data - JSON-LD */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Hanif Adedotun",
      "url": "https://v2.hanif.one",
      "email": "hey@hanif.one",
      "jobTitle": "Software Engineer",
      "sameAs": [
        "https://github.com/hanif-adedotun",
        "https://x.com/@devhanif",
        "https://linkedin.com/in/hanif-adedotun"
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Hanif Adedotun - Portfolio",
      "url": "https://v2.hanif.one",
      "author": {
        "@type": "Person",
        "name": "Hanif Adedotun"
      }
    })} />

    <Footer />
  </div>
</Layout>
