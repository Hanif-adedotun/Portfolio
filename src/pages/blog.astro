---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Icon } from "astro-icon/components";
import blogPosts from "../data/blog-posts.json";
---

<Layout 
  title="Blog - Hanif Adedotun"
  description="Technical blog by Hanif Adedotun covering software engineering, AI agents, and web development insights."
  canonicalUrl="https://v2.hanif.one/blog"
>
  <div class="min-h-screen p-6 max-w-4xl mx-auto">
    <Header />

    <main class="space-y-12">
      <section class="animate-fade-in-up">
        <div class="flex items-center justify-between mb-8">
          <h1 class="text-4xl font-bold text-gray-900 dark:text-white">
            All Articles
          </h1>
        </div>
        
        <!-- Search Input -->
        <div class="mb-8 relative">
          <div class="relative">
            <Icon 
              name="mdi:magnify" 
              class="absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400 dark:text-gray-500 pointer-events-none"
            />
            <input
              type="text"
              id="blog-search"
              placeholder="Search articles by title, author, or content..."
              class="w-full pl-12 pr-4 py-3 bg-transparent border border-gray-300 dark:border-gray-700 rounded-lg text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1DCFF6] focus:border-transparent transition-all duration-300"
            />
          </div>
        </div>

        <!-- Results Count -->
        <div id="results-count" class="mb-4 text-sm text-gray-600 dark:text-gray-400 hidden">
          <span id="results-text"></span>
        </div>

        <!-- Blog Posts Container -->
        <div id="blog-posts-container" class="space-y-6">
          {blogPosts.map((post, index) => (
            <article 
              data-title={post.title.toLowerCase()}
              data-author={post.author.toLowerCase()}
              data-intro={post.intro.toLowerCase()}
              data-slug={post.slug}
              class="blog-post border-b border-gray-200 dark:border-gray-800 pb-6 last:border-0 transition-all duration-300 hover:translate-x-1"
              style={`animation: fadeInUp 0.5s ease-out ${index * 100}ms both`}
            >
              <a
                href={`/blog/${post.slug}`}
                class="block group transition-all duration-300"
              >
                <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-contrast transition-colors duration-300 group-hover:underline">
                  {post.title}
                </h2>
                <p class="text-base text-gray-600 dark:text-gray-400 mb-3 line-clamp-2 group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors duration-300">
                  {post.intro}
                </p>
                <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-500">
                  <span>{post.author}</span>
                  <span>•</span>
                  <time datetime={post.date}>
                    {new Date(post.date).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </div>
              </a>
            </article>
          ))}
        </div>

        <!-- No Results Message -->
        <div id="no-results" class="hidden text-center py-12">
          <p class="text-gray-600 dark:text-gray-400 text-lg">
            No articles found matching your search.
          </p>
        </div>
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline>
    const searchInput = document.getElementById('blog-search');
    const blogPostsContainer = document.getElementById('blog-posts-container');
    const noResults = document.getElementById('no-results');
    const resultsCount = document.getElementById('results-count');
    const resultsText = document.getElementById('results-text');
    const blogPosts = document.querySelectorAll('.blog-post');
    const totalPosts = blogPosts.length;

    function filterPosts(searchTerm) {
      const term = searchTerm.toLowerCase().trim();
      let visibleCount = 0;

      blogPosts.forEach((post) => {
        const title = post.getAttribute('data-title') || '';
        const author = post.getAttribute('data-author') || '';
        const intro = post.getAttribute('data-intro') || '';
        
        const matches = title.includes(term) || 
                       author.includes(term) || 
                       intro.includes(term);

        if (matches || term === '') {
          post.style.display = 'block';
          visibleCount++;
        } else {
          post.style.display = 'none';
        }
      });

      // Show/hide results count
      if (term === '') {
        resultsCount.classList.add('hidden');
        noResults.classList.add('hidden');
      } else {
        resultsCount.classList.remove('hidden');
        resultsText.textContent = `${visibleCount} of ${totalPosts} article${totalPosts !== 1 ? 's' : ''} found`;
        
        // Show/hide no results message
        if (visibleCount === 0) {
          noResults.classList.remove('hidden');
          blogPostsContainer.classList.add('hidden');
        } else {
          noResults.classList.add('hidden');
          blogPostsContainer.classList.remove('hidden');
        }
      }
    }

    // Debounce function to limit search frequency
    let searchTimeout;
    searchInput?.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        filterPosts(e.target.value);
      }, 150);
    });

    // Clear search on Escape key
    searchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        filterPosts('');
        searchInput.blur();
      }
    });
  </script>
</Layout>