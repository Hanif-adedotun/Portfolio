---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import blogPosts from "../data/blog-posts.json";
---

<Layout 
  title="Blog - Hanif Adedotun"
  description="Technical blog by Hanif Adedotun covering software engineering, AI agents, and web development insights."
  canonicalUrl="https://v2.hanif.one/blog"
>
  <div class="min-h-screen p-6 max-w-4xl mx-auto">
    <Header />

    <main class="space-y-12">
      <section class="animate-fade-in-up">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">
          All Articles
        </h1>
        <div class="space-y-6">
          {blogPosts.map((post, index) => (
            <article 
              class="border-b border-gray-200 dark:border-gray-800 pb-6 last:border-0 transition-all duration-300 hover:translate-x-1"
              style={`animation: fadeInUp 0.5s ease-out ${index * 100}ms both`}
            >
              <a
                href={`/blog/${post.slug}`}
                class="block group transition-all duration-300"
              >
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-contrast transition-colors duration-300 group-hover:underline">
                  {post.title}
                </h2>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-3 line-clamp-2 group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors duration-300">
                  {post.intro}
                </p>
                <div class="flex items-center gap-4 text-xs text-gray-500 dark:text-gray-500">
                  <span>{post.author}</span>
                  <span>•</span>
                  <time datetime={post.date}>
                    {new Date(post.date).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    </main>
  </div>
</Layout>

