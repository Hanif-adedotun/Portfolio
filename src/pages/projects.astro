---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Icon } from "astro-icon/components";
import projects from "../data/projects.json";
---

<Layout 
  title="Projects - Hanif Adedotun"
  description="Portfolio of software projects by Hanif Adedotun, featuring web applications and development work."
  canonicalUrl="https://v2.hanif.one/projects"
>
  <div class="min-h-screen p-6 max-w-4xl mx-auto">
    <Header />

    <main class="space-y-12 mt-8">
      <section class="animate-fade-in-up">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-8">
          Projects
        </h1>
        <div class="space-y-8">
          {projects.map((project, index) => (
            <article 
              class="border-b border-gray-200 dark:border-gray-800 pb-8 last:border-0 transition-all duration-300 hover:translate-x-1 group"
              style={`animation: fadeInUp 0.5s ease-out ${index * 100}ms both`}
            >
              <div class="flex items-start justify-between gap-4 mb-3">
                <h2 class="text-2xl font-semibold text-gray-900 dark:text-white group-hover:text-contrast transition-colors duration-300">
                  <a
                  href={project.name[1]}
                  target="_blank"
                  rel="noopener noreferrer">{project.name[0]}</a>
                  
                </h2>
                <a
                  href={project.name[1]}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-500 dark:text-gray-400 hover:text-contrast transition-all duration-300 hover:scale-110 shrink-0"
                  aria-label={`Visit ${project.name[0]}`}
                >
                  <Icon name="mdi:web" class="w-5 h-5" />
                </a>
              </div>
              <p class="text-base text-gray-600 dark:text-gray-400 mb-4 leading-relaxed group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors duration-300">
                {project.summary}
              </p>
              <div class="flex flex-wrap gap-2">
                {project.tools.map((tool: string, toolIndex: number) => (
                  <span 
                    class="text-sm px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 transition-all duration-300 hover:scale-105 hover:bg-gray-200 dark:hover:bg-gray-700 hover:border-contrast"
                    style={`animation: scaleIn 0.3s ease-out ${(index * 100) + (toolIndex * 50) + 200}ms both`}
                  >
                    {tool}
                  </span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

