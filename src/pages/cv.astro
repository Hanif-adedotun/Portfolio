---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Icon } from "astro-icon/components";
---

<Layout 
  title="Resume - Hanif Adedotun"
  description="Resume and academic CV of Hanif Adedotun, software engineer and developer."
  canonicalUrl="https://v2.hanif.one/cv"
>
  <div class="min-h-screen p-6 max-w-4xl mx-auto">
    <Header />

    <main class="space-y-12 mt-8">
      <section class="animate-fade-in-up">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-8">
          Resume
        </h1>
        <div class="space-y-6">
          <div 
            class="transition-all duration-300 hover:translate-x-1"
            style="animation: fadeInUp 0.5s ease-out 100ms both"
          >
            <a
             href="https://docs.google.com/document/d/1sC0lsScDSwPbR-SpXfl6cY_rcB67E4sgOdKBeQMlWqc/edit?usp=sharing"
             
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-base text-gray-900 dark:text-white hover:text-contrast transition-all duration-300 underline group"
            >
              Resume
              <Icon name="mdi:download" class="w-4 h-4 group-hover:scale-110 transition-transform duration-300" />
            </a>
          </div>
          <div 
            class="transition-all duration-300 hover:translate-x-1"
            style="animation: fadeInUp 0.5s ease-out 200ms both"
          >
            <a
              href="https://docs.google.com/document/d/1KSpU9eojLUHrX8ETWiE388v2JlEBDXPFipkClBi-ivc/edit?usp=sharing"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-base text-gray-900 dark:text-white hover:text-contrast transition-all duration-300 underline group"
            >
              Academic CV
              <Icon name="mdi:download" class="w-4 h-4 group-hover:scale-110 transition-transform duration-300" />
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>