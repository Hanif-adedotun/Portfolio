---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Resume">
  <div class="min-h-screen p-6 max-w-4xl mx-auto">
    <Header />

    <main class="space-y-12 mt-8">
      <section class="animate-fade-in-up">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">
          Resume
        </h1>
        <div class="space-y-6">
          <div 
            class="transition-all duration-300 hover:translate-x-1"
            style="animation: fadeInUp 0.5s ease-out 100ms both"
          >
            <a
              href="https://docs.google.com/document/d/1KSpU9eojLUHrX8ETWiE388v2JlEBDXPFipkClBi-ivc/edit?usp=sharing"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-gray-900 dark:text-white hover:text-contrast transition-all duration-300 underline group"
            >
              Resume
              <Icon name="mdi:download" class="w-4 h-4 group-hover:scale-110 transition-transform duration-300" />
            </a>
          </div>
          <div 
            class="transition-all duration-300 hover:translate-x-1"
            style="animation: fadeInUp 0.5s ease-out 200ms both"
          >
            <a
              href="https://docs.google.com/document/d/1sC0lsScDSwPbR-SpXfl6cY_rcB67E4sgOdKBeQMlWqc/edit?usp=sharing"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-gray-900 dark:text-white hover:text-contrast transition-all duration-300 underline group"
            >
              Academic CV
              <Icon name="mdi:download" class="w-4 h-4 group-hover:scale-110 transition-transform duration-300" />
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer
      class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-800 text-sm text-gray-500 text-center animate-fade-in-delay"
    >
      <p class="mb-2">
        © {new Date().getFullYear()} Hanif Adedotun. | All Rights Reserved.
      </p>
      <p>
        Source code is available at
        <a
          href="https://github.com/Hanif-adedotun/Portfolio-v2"
          class="text-gray-600 dark:text-gray-400 hover:text-contrast transition-colors duration-300 underline"
          >github.com/hanif-adedotun/Portfolio-v2</a
        >
      </p>
    </footer>
  </div>
</Layout>

